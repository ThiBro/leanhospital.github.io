---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "title_de": {{ post.title_de | default: post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%B %d, %Y" | jsonify }},
      "content": {{ post.description | default: post.content | strip_html | strip_newlines | truncate: 400 | jsonify }},
      "content_de": {{ post.description_de | default: post.description | default: post.content | strip_html | strip_newlines | truncate: 400 | jsonify }},
      "image": {{ post.image | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
